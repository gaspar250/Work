{
  "entities": {
    "User": {
      "title": "User",
      "description": "A client or service provider in the MatchTask app.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["client", "provider", "both"] },
        "bio": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "reviewCount": { "type": "integer" },
        "isOnline": { "type": "boolean" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "portfolio": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "imageURL": { "type": "string", "format": "uri" }
            }
          } 
        },
        "location": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" } } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "role"]
    },
    "Task": {
      "title": "Task",
      "description": "A job request or completed service.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "providerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "completed", "cancelled"] },
        "price": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["multicaixa", "mpesa"] },
        "rated": { "type": "boolean" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "clientReminderSent": { "type": "boolean" },
        "providerReminderSent": { "type": "boolean" },
        "reminderSent": { "type": "boolean" }, // Keeping for backward compatibility or simple check
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "title", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message between client and provider.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text"]
    },
    "Notification": {
      "title": "Notification",
      "description": "An in-app notification for the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string", "enum": ["message", "proposal", "task_update"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "body", "type"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "A provider favorited by a user.",
      "type": "object",
      "properties": {
        "providerId": { "type": "string" },
        "providerName": { "type": "string" },
        "providerPhoto": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["providerId"]
    },
    "Review": {
      "title": "Review",
      "description": "A review given by a client to a provider.",
      "type": "object",
      "properties": {
        "taskId": { "type": "string" },
        "clientId": { "type": "string" },
        "providerId": { "type": "string" },
        "clientName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["taskId", "clientId", "providerId", "rating"]
    },
    "Job": {
      "title": "Job",
      "description": "A public job offer posted by a client.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "title", "description", "category"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/users/{uid}/favorites/{providerId}": { "schema": "Favorite", "description": "User's favorite providers" },
    "/tasks/{taskId}": { "schema": "Task", "description": "Job records" },
    "/chats/{chatId}/messages/{messageId}": { "schema": "Message", "description": "Chat messages" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications" },
    "/reviews/{reviewId}": { "schema": "Review", "description": "Provider reviews" },
    "/jobs/{jobId}": { "schema": "Job", "description": "Public job offers" }
  }
}
